            const filtered = category === '全部' ? projectsData : projectsData.filter(p => p.category === category);
            
            grid.innerHTML = filtered.map(p => `
                <div class="glass-card project-card tilt-card hover-effect" onclick="openDetail(${p.id})">
                    <div class="proj-category">${p.category}</div>
                    <div class="proj-title">${p.title}</div>
                    <div class="proj-desc">${p.desc}</div>
                    <div class="proj-more">了解详情 →</div>
                </div>
            `).join('');

            initTiltEffect();
            initHoverLight();
        }

        // 切换项目分类
        function filterProjects(category) {
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.toggle('active', btn.innerText === category);
            });
            renderProjects(category);
        }

        // 打开项目详情
        function openDetail(id) {
            const project = projectsData.find(p => p.id === id);
            if(!project) return;

            document.getElementById('detail-category').innerText = project.category;
            document.getElementById('detail-title').innerText = project.title;
            document.getElementById('detail-time').innerText = "时间: " + project.time;
            document.getElementById('detail-company').innerText = "所在公司: " + project.company;
            document.getElementById('detail-role').innerText = "主要职责: " + project.role;
            document.getElementById('detail-content').innerText = project.detail;

            switchPage('project-detail');
        }

        // tvOS 3D 悬浮视差动效 (Apple空间计算核心细节)
        function initTiltEffect() {
            document.querySelectorAll('.tilt-card').forEach(card => {
                card.addEventListener('mousemove', e => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    // 计算倾斜角度，限制在正负8度以内保持丝滑
                    const rotateX = ((y - centerY) / centerY) * -8; 
                    const rotateY = ((x - centerX) / centerX) * 8;
                    
                    card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
                });
                card.addEventListener('mouseleave', () => {
                    card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
                });
            });
        }

        // 微玻璃拟态呼吸光效 (鼠标跟随发光)
        function initHoverLight() {
            document.querySelectorAll('.hover-effect').forEach(card => {
                card.addEventListener('mousemove', e => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    card.style.setProperty('--mouse-x', `${x}px`);
                    card.style.setProperty('--mouse-y', `${y}px`);
                });
            });
        }

        // 初始化
        window.onload = () => {
            renderWork();
            renderProjects();
        };

    </script>
</body>
</html>
