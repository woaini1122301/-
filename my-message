<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>个人简历 | 空间计算美学</title>
    <style>
        /* 基础与变量配置 */
        :root {
            --bg-color: #000000;
            --text-primary: #ffffff;
            --text-secondary: rgba(255, 255, 255, 0.6);
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --glass-hover: rgba(255, 255, 255, 0.08);
            --accent-color: #0071e3;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-primary);
            overflow-x: hidden;
            line-height: 1.6;
        }

        /* 深邃黑背景 + 极光流光动效 */
        .aurora-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: -1;
            background: radial-gradient(circle at 15% 50%, rgba(20, 50, 100, 0.4), transparent 50%),
                        radial-gradient(circle at 85% 30%, rgba(60, 20, 80, 0.3), transparent 50%);
            filter: blur(60px);
            animation: auroraMove 20s ease-in-out infinite alternate;
        }
        @keyframes auroraMove {
            0% { transform: scale(1) translate(0, 0); }
            100% { transform: scale(1.2) translate(-50px, 50px); }
        }

        /* 文字导航栏 */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 20px 40px;
            display: flex;
            justify-content: center;
            gap: 40px;
            z-index: 100;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
        }
        nav a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.3s;
            cursor: pointer;
        }
        nav a:hover, nav a.active {
            color: var(--text-primary);
        }

        /* 页面容器与切换逻辑 */
        main {
            padding: 100px 5% 50px;
            max-width: 1200px;
            margin: 0 auto;
            min-height: 100vh;
        }
        .page-view {
            display: none;
            animation: fadeIn 0.5s ease;
        }
        .page-view.active {
            display: block;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* 微玻璃拟态卡片 (通用) */
        .glass-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 30px;
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            position: relative;
            overflow: hidden;
        }
        /* 呼吸光效 */
        .glass-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.06), transparent 40%);
            opacity: 0;
            transition: opacity 0.5s;
            pointer-events: none;
            z-index: 0;
        }
        .glass-card:hover::before { opacity: 1; }
        .glass-card > * { position: relative; z-index: 1; }

        /* 首页视图 */
        .hero {
            height: 70vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }
        .hero h1 { font-size: 64px; font-weight: 700; margin-bottom: 16px; letter-spacing: -1px; }
        .hero p { font-size: 24px; color: var(--text-secondary); font-weight: 300; }

        /* 工作履历视图 */
        .work-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 24px 30px;
            margin-bottom: 16px;
            cursor: pointer;
        }
        .work-left { display: flex; align-items: center; gap: 20px; }
        .company-logo { width: 48px; height: 48px; border-radius: 12px; background: #222; display: flex; align-items: center; justify-content: center; font-weight: bold; }
        .work-title { font-size: 20px; font-weight: 600; }
        .work-right { text-align: right; color: var(--text-secondary); }
        .work-desc {
            max-height: 0;
            opacity: 0;
            overflow: hidden;
            transition: all 0.4s ease;
            color: var(--text-secondary);
            font-size: 14px;
            margin-top: 0;
        }
        .work-row:hover .work-desc {
            max-height: 100px;
            opacity: 1;
            margin-top: 16px;
        }

        /* 项目经验视图 (Bento Grid) */
        .filter-bar {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 30px;
        }
        .filter-btn {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            color: var(--text-secondary);
            padding: 8px 20px;
            border-radius: 30px;
            cursor: pointer;
            transition: 0.3s;
        }
        .filter-btn.active, .filter-btn:hover {
            background: var(--text-primary);
            color: var(--bg-color);
        }
        .bento-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        .project-card {
            height: 280px;
            display: flex;
            flex-direction: column;
            cursor: pointer;
            transform-style: preserve-3d;
        }
        .proj-category { font-size: 12px; color: var(--accent-color); font-weight: 600; margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px; }
        .proj-title { font-size: 18px; font-weight: 600; margin-bottom: 12px; }
        .proj-desc { font-size: 14px; color: var(--text-secondary); flex-grow: 1; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; }
        .proj-more { align-self: flex-end; font-size: 14px; color: var(--text-primary); display: flex; align-items: center; gap: 4px; opacity: 0; transform: translateX(-10px); transition: 0.3s; }
        .project-card:hover .proj-more { opacity: 1; transform: translateX(0); }

        /* 详情页视图 (三级页面) */
        .back-btn { display: inline-block; margin-bottom: 30px; color: var(--text-secondary); cursor: pointer; }
        .back-btn:hover { color: var(--text-primary); }
        .detail-header { margin-bottom: 40px; }
        .detail-title { font-size: 40px; margin-bottom: 16px; }
        .detail-meta { display: flex; gap: 24px; color: var(--text-secondary); font-size: 16px; margin-bottom: 30px; border-bottom: 1px solid var(--glass-border); padding-bottom: 20px; }
        .detail-content { font-size: 16px; color: #ddd; line-height: 1.8; white-space: pre-line; }

    </style>
</head>
